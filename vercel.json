{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/functions" },
    { "source": "/scripts/(.*)", "destination": "/src/scripts/$1" },
    { "source": "/fonts/(.*)", "destination": "/src/fonts/$1" },
    { "source": "/images/(.*)", "destination": "/src/images/$1" },
    { "source": "/styles/(.*)", "destination": "/src/styles/$1" },
    { "source": "/(.*)", "destination": "/src/index.html" }
  ]
}
